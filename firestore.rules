rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global lock - deny all by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && 
             request.auth.token.email != null &&
             exists(/databases/$(database)/documents/admins/$(request.auth.token.email.toLowerCase()));
    }

    // configs collection: schoolConfig holds global profile metadata
    match /configs/schoolConfig {
      allow read: if true;
      allow write: if isAdmin();
    }

    // admins collection: Document ID is the admin's email address
    match /admins/{email} {
      allow read, write: if isAdmin();
    }

    // categories collection: active training systems
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // faqs collection: stored Q&A
    match /faqs/{faqId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // history collection: telemetry chat logs
    match /history/{historyId} {
      allow read, write: if true;
    }

    // consultations collection: enrollment contact cards
    match /consultations/{consultationId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }
  }
}
